# ==========================================
# Anti-Bot & Proxy Configuration
# ==========================================
# Set a proxy server to rotate IPs and avoid rate limiting
# Example: http://username:password@proxyserver.com:8080
# PROXY_SERVER=http://127.0.0.1:7890

# ==========================================
# LLM Post-Processing Configuration
# ==========================================
# Set the API key to enable automatic AI correction of mixed-language errors
# (e.g., correcting "sgail" -> "skill", "普龙特" -> "prompt")
# 
# Example: If using DeepSeek or OpenAI, provide your API key below.
LLM_API_KEY=your_api_key_here

# Base URL for the LLM API. 
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
LLM_API_BASE_URL=https://api.openai.com/v1

# The model to use. e.g., gpt-4o-mini, deepseek-chat
LLM_MODEL=gpt-4o-mini
